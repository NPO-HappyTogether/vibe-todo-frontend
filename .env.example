# 백엔드 API Base URL
# - 비워두면 Vite 프록시(/todos → localhost:5000)를 사용 (로컬 백엔드 개발용)
# - 값을 채우면 해당 URL로 직접 요청 (배포된 백엔드 사용)
#
# 로컬 백엔드 사용 시:
#   VITE_API_BASE_URL=
#
# 배포된 백엔드 사용 시:
#   VITE_API_BASE_URL=https://vibe-todo-backend-production-aee0.up.railway.app/todos

VITE_API_BASE_URL=https://vibe-todo-backend-production-aee0.up.railway.app/todos
