# 이 파일은 환경변수 템플릿입니다.
# 실제 값을 채워서 ".env" 파일로 복사한 뒤 사용하세요.
#   cp .env.example .env
#
# 백엔드 API Base URL
# - 비워두면 Vite 프록시(/todos → localhost:5000)를 사용 (로컬 백엔드 개발용)
# - 값을 채우면 해당 URL로 직접 요청 (배포된 백엔드 사용)
#
# 예시:
#   VITE_API_BASE_URL=                              (로컬 백엔드)
#   VITE_API_BASE_URL=https://your-backend.com/todos (배포된 백엔드)

VITE_API_BASE_URL=
